# Stellar Horizon API endpoint used for ingestion.
# Default: https://horizon.stellar.org
# Optional.
HORIZON_URL=https://horizon.stellar.org

# Network passphrase used when submitting Soroban transactions.
# Options: PUBLIC, TESTNET
# Default: PUBLIC
# Optional.
STELLAR_NETWORK=PUBLIC

# Assets/pairs to monitor, comma-separated CODE:ISSUER pairs (use "native" as the
# issuer for XLM).
# Default: a single sample USDC:issuer pair (see config.py).
# Required.
WATCHED_ASSET_PAIRS=USDC:GA5Z...,XLM:native

# AMM liquidity pool IDs to monitor, comma-separated 64-char lowercase hex strings.
# Each ID must be a valid Stellar liquidity pool ID (64 lowercase hex chars).
# Example: WATCHED_AMM_POOLS=abcd1234...(64 chars),ef012345...(64 chars)
# Default: empty (no pools monitored).
# Optional.
WATCHED_AMM_POOLS=

# Rolling window sizes (hours) used by the Benford engine, comma-separated integers.
# Default: 1,4,24,168,720
# Optional.
BENFORD_WINDOWS_HOURS=1,4,24,168,720

# Time window (seconds) used when comparing transactions across asset pairs for
# cross-pair synchrony detection.
# Default: 30
# Optional.
CROSS_PAIR_SYNCHRONY_WINDOW_SECONDS=30

# Minimum number of trades required before a wallet is scored.
# Default: 20
# Optional.
MIN_TRADES_FOR_SCORING=20

# Risk score (0-100) at or above which a wallet is flagged.
# Default: 70
# Optional.
RISK_SCORE_FLAG_THRESHOLD=70

# SQLAlchemy connection URL for storing computed risk scores.
# Default: sqlite:///ledgerlens.db
# Optional.
RISK_SCORE_DB_URL=sqlite:///ledgerlens.db

# Database connection pooling settings (SQLAlchemy engine options).
# Defaults: DB_POOL_SIZE=5, DB_MAX_OVERFLOW=10, DB_POOL_TIMEOUT=30 (seconds)
# Optional.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Directory where trained model artifacts are read from/written to.
# Default: ./models
# Optional.
MODEL_DIR=./models

# ledgerlens-score Soroban contract integration (integrations/contract_client.py).
# Soroban RPC endpoint used to submit forensic reports on-chain.
# Default: https://soroban-testnet.stellar.org
# Optional.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Deployed contract ID of the ledgerlens-score Soroban contract.
# Default: empty.
# Required only when submitting reports on-chain (require_onchain=True).
LEDGERLENS_CONTRACT_ID=
# Stellar secret key (starts with "S") used to sign and submit contract transactions.
# Default: empty.
# Required only when submitting reports on-chain (require_onchain=True).
# WARNING: Never commit this value to version control.
LEDGERLENS_SUBMITTER_SECRET=

# Real-time streaming / alerting (scripts/stream.py)
# Ingestion transport: "sse" (default, thread-per-pair Horizon SSE) or "kafka".
# Default: sse
# Optional.
STREAMING_BACKEND=sse

# ---------------------------------------------------------------------------
# Kafka streaming backend (only used when STREAMING_BACKEND=kafka)
# ---------------------------------------------------------------------------
# Comma-separated host:port list of Kafka brokers.
# Default: localhost:9092
# Required when STREAMING_BACKEND=kafka.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# SASL credentials are read from these env vars ONLY — never commit real values.
# Default: empty (SASL auth disabled).
# Optional; required only if the Kafka cluster enforces SASL auth.
# WARNING: Never commit real credentials to version control.
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
# Consumer lag (messages behind the high watermark) that triggers a CRITICAL log.
# Default: 500
# Optional.
KAFKA_LAG_ALERT_THRESHOLD=500
# Kafka consumer group ID for the trade-scoring workers.
# Default: ledgerlens-scorer
# Optional.
KAFKA_CONSUMER_GROUP=ledgerlens-scorer
# Port the Kafka consumer exposes Prometheus metrics on.
# Default: 9100
# Optional.
KAFKA_METRICS_PORT=9100

# Alert delivery channel used by scripts/stream.py.
# Options: stdout, webhook, websocket
# Default: stdout
# Optional.
ALERT_CHANNEL=stdout
# HTTPS endpoint to POST alerts to.
# Default: empty.
# Required when ALERT_CHANNEL=webhook.
ALERT_WEBHOOK_URL=
# Minimum seconds between repeat alerts for the same wallet/rule.
# Default: 3600
# Optional.
ALERT_COOLDOWN_SECONDS=3600
# NDJSON file that alerts are appended to when delivery fails.
# Default: alerts_dlq.ndjson
# Optional.
ALERT_DEAD_LETTER_PATH=alerts_dlq.ndjson
# TCP port the WebSocket alert server listens on.
# Default: 8765
# Optional.
WS_PORT=8765
# Network interface the WebSocket server binds to.
# Default: 127.0.0.1 (loopback only)
# Optional.
WS_BIND_HOST=127.0.0.1
# Set WS_ALLOW_EXTERNAL=1 to bind the WebSocket server to 0.0.0.0 (non-loopback).
# Default: empty (disabled — loopback only).
# Optional.
WS_ALLOW_EXTERNAL=

# WebSocket pub/sub server authentication and limits (streaming/ws_server.py)
# Path to the PEM-encoded public key used to verify client JWTs.
# Default: ./jwt_public_key.pem
# Optional.
JWT_PUBLIC_KEY_PATH=./jwt_public_key.pem
# Maximum number of concurrent WebSocket clients.
# Default: 200
# Optional.
WS_MAX_CLIENTS=200
# Maximum number of buffered outbound messages per client before it is disconnected.
# Default: 100
# Optional.
WS_CLIENT_QUEUE_DEPTH=100
# Number of recent messages kept for replay to newly-connected clients.
# Default: 1000
# Optional.
WS_REPLAY_BUFFER_SIZE=1000
# Maximum inbound messages accepted per client per second.
# Default: 100
# Optional.
WS_RATE_LIMIT_MSGS_PER_SECOND=100

# ---------------------------------------------------------------------------
# Model integrity — DO NOT COMMIT THESE VALUES
# ---------------------------------------------------------------------------

# Path to the Ed25519 PEM private key used to sign metrics.json after training.
# Generate with: openssl genpkey -algorithm ed25519 -out signing_key.pem
# Default: empty.
# Required for model signing; otherwise optional.
# WARNING: Never commit this file or its contents to version control.
MODEL_SIGNING_PRIVATE_KEY_PATH=

# SHA-256 fingerprint of the trusted Ed25519 public key (hex).
# Used by verify_chain() to confirm the artifact was signed by the expected key.
# Default: empty.
# Required for signature verification; otherwise optional.
TRUSTED_SIGNING_KEY_FINGERPRINT=

# Append-only NDJSON log of signed forensic report commitments.
# Default: data/audit_trail.ndjson
# Optional.
AUDIT_LOG_PATH=data/audit_trail.ndjson

# Optional Ed25519 public key PEM for verify_audit_trail.py (defaults to private-key pair).
# Default: empty.
# Optional.
AUDIT_VERIFY_PUBLIC_KEY_PATH=

# BFT voting thresholds (defaults shown).
# BFT_SCORE_DIVERGENCE_THRESHOLD: max allowed score divergence between voters.
# BFT_MIN_CONSENSUS: minimum number of voters that must agree.
# Defaults: BFT_SCORE_DIVERGENCE_THRESHOLD=30, BFT_MIN_CONSENSUS=2
# Optional.
BFT_SCORE_DIVERGENCE_THRESHOLD=30
BFT_MIN_CONSENSUS=2

# Maximum allowed shift in wash-trade label ratio before training is aborted
# (data-poisoning guard).
# Default: 0.15
# Optional.
POISON_LABEL_RATIO_THRESHOLD=0.15

# HMAC secret for annotation queue integrity.
# Default: empty.
# Required for annotation queue signing; otherwise optional.
# WARNING: Never commit this value to version control.
ANNOTATION_HMAC_SECRET=

# ---------------------------------------------------------------------------
# Adversarial training (disabled by default)
# ---------------------------------------------------------------------------

# Ratio of adversarially-perturbed copies added per clean training sample when
# --adversarial-augmentation is passed to detection/model_training.py.
# 0.0 = disabled (default).  Typical useful range: 0.25-1.0.
# Optional.
ADVERSARIAL_AUG_RATIO=0.0

# ---------------------------------------------------------------------------
# Differentially private neural training (DP-SGD / Opacus)
# ---------------------------------------------------------------------------

# Target privacy budget (epsilon) for DANN encoder and meta-learner training.
# Default: 8.0
# Optional.
DP_TARGET_EPSILON=8.0
# Target privacy budget (delta) for DANN encoder and meta-learner training.
# Default: 1e-5
# Optional.
DP_TARGET_DELTA=1e-5
# Maximum L2 norm gradients are clipped to before noise is added (DP-SGD).
# Default: 1.0
# Optional.
DP_MAX_GRAD_NORM=1.0
# Number of training epochs for DP-SGD runs.
# Default: 50
# Optional.
DP_EPOCHS=50

# ---------------------------------------------------------------------------
# Active learning
# ---------------------------------------------------------------------------

# Query strategy for selecting wallets to annotate.
# Options: least_confidence, margin, entropy, coreset, badge, committee_disagreement
# Default: committee_disagreement
# Optional.
AL_QUERY_STRATEGY=committee_disagreement

# Number of wallets to select per active learning run.
# Default: 20
# Optional.
AL_BATCH_SIZE=20

# Minimum new labelled samples to trigger a full retrain (vs warm-start).
# Default: 50
# Optional.
AL_RETRAIN_THRESHOLD=50

# Maximum allowed AUC-ROC drop before rolling back a model update.
# Default: 0.01
# Optional.
AL_ROLLBACK_AUC_DROP=0.01

# Path to the annotation queue JSON file.
# Default: data/annotation_queue.json
# Optional.
AL_QUEUE_PATH=data/annotation_queue.json

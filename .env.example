# Horizon API endpoint used for ingestion
HORIZON_URL=https://horizon.stellar.org

# Network passphrase (testnet/mainnet)
STELLAR_NETWORK=PUBLIC

# Assets/pairs to monitor, comma-separated CODE:ISSUER pairs
WATCHED_ASSET_PAIRS=USDC:GA5Z...,XLM:native

# Rolling window sizes (hours) used by the Benford engine
BENFORD_WINDOWS_HOURS=1,4,24,168,720

# Risk score thresholds
RISK_SCORE_FLAG_THRESHOLD=70

# Storage backend for computed risk scores
RISK_SCORE_DB_URL=sqlite:///ledgerlens.db

# Trained model artifact paths
MODEL_DIR=./models

# ledgerlens-score Soroban contract
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
LEDGERLENS_CONTRACT_ID=
LEDGERLENS_SUBMITTER_SECRET=

# Real-time streaming / alerting (scripts/stream.py)
ALERT_CHANNEL=stdout
ALERT_WEBHOOK_URL=
ALERT_COOLDOWN_SECONDS=3600
WS_PORT=8765
WS_BIND_HOST=127.0.0.1
# Set WS_ALLOW_EXTERNAL=1 to bind the WebSocket server to 0.0.0.0 (non-loopback)
WS_ALLOW_EXTERNAL=

# ---------------------------------------------------------------------------
# Model integrity — DO NOT COMMIT THESE VALUES
# ---------------------------------------------------------------------------

# Path to the Ed25519 PEM private key used to sign metrics.json after training.
# Generate with: openssl genpkey -algorithm ed25519 -out signing_key.pem
# WARNING: Never commit this file or its contents to version control.
MODEL_SIGNING_PRIVATE_KEY_PATH=

# SHA-256 fingerprint of the trusted Ed25519 public key (hex).
# Used by verify_chain() to confirm the artifact was signed by the expected key.
TRUSTED_SIGNING_KEY_FINGERPRINT=

# BFT voting thresholds (defaults shown)
BFT_SCORE_DIVERGENCE_THRESHOLD=30
BFT_MIN_CONSENSUS=2

# Maximum allowed shift in wash-trade label ratio before training is aborted
POISON_LABEL_RATIO_THRESHOLD=0.15

# HMAC secret for annotation queue integrity.
# WARNING: Never commit this value to version control.
ANNOTATION_HMAC_SECRET=

# ---------------------------------------------------------------------------
# Adversarial training (disabled by default)
# ---------------------------------------------------------------------------

# Ratio of adversarially-perturbed copies added per clean training sample when
# --adversarial-augmentation is passed to detection/model_training.py.
# 0.0 = disabled (default).  Typical useful range: 0.25–1.0.
ADVERSARIAL_AUG_RATIO=0.0
